{
  "name": "google-sheets-excel-template",
  "version": "1.5.34",
  "description": "",
  "main": "lib/index",
  "scripts": {
    "start": "./node_modules/.bin/ts-node -- ./src/boot.ts",
    "build": "rm -rf lib; ./node_modules/.bin/tsc -d -p tsconfig.npm.json",
    "dev": "./node_modules/.bin/nodemon --exec ./node_modules/.bin/ts-node --type-check -- ./src/boot.ts",
    "debug": "./node_modules/.bin/nodemon --exec node --inspect --trace-warnings -r ./node_modules/ts-node/register -- ./src/boot.ts",
    "debug-trace": "./node_modules/.bin/nodemon --exec node --inspect --trace-sync-io -r ./node_modules/ts-node/register -- ./src/boot.ts",
    "test-dev": "./node_modules/.bin/nodemon --exec \"yarn test || true\"",
    "test": "NODE_OPTIONS=\"--trace-warnings\" yarn test-ts --trace-warnings && ./node_modules/.bin/tsc --noEmit && yarn lint",
    "test-ts": "./node_modules/.bin/mocha --exit -r ./node_modules/ts-node/register test/**/test.ts",
    "test:single": "NODE_OPTIONS=\"--trace-warnings\" ./node_modules/.bin/mocha --exit -r ./node_modules/ts-node/register \"$1\"",
    "lint": "./node_modules/.bin/tslint -c tslint.json 'src/**/*.ts' 'bin/**/*.ts' 'test/**/*.ts' -p tsconfig.json",
    "lint-fix": "./node_modules/.bin/tslint --fix -c tslint.json 'src/**/*.ts' 'bin/**/*.ts' 'test/**/*.ts' -p tsconfig.json",
    "lint-dependencies": "./node_modules/.bin/depcheck . --ignores '@types/*,depcheck,tslint-language-service' --ignore-dirs 'lib'",
    "prepack": "rm -rf lib; ./node_modules/.bin/tsc -d -p tsconfig.npm.json",
    "generate-api-key": "ts-node -r dotenv/config -e \"import * as crypto from 'crypto'; import * as apiKey from './src/server/api_key'; console.log(apiKey.fromNonce(crypto.randomBytes(32).toString('hex')))\"",
    "simulate": "./node_modules/.bin/ts-node -- ./simulate/simulate.ts"
  },
  "keywords": [
    "looker",
    "data",
    "action"
  ],
  "author": "bwebs",
  "organization": "lkr-dev",
  "license": "MIT",
  "dependencies": {
    "@types/base64-url": "^2.2.0",
    "@types/body-parser": "^1.19.0",
    "@types/dotenv": "^4.0.1",
    "@types/express": "^4.17.17",
    "@types/node": "^20.14.15",
    "@types/normalize-url": "3.3.0",
    "@types/oboe": "^2.0.29",
    "@types/raven": "^2.5.3",
    "@types/request": "^2.48.5",
    "@types/sanitize-filename": "^1.6.3",
    "@types/semver": "^5.4.0",
    "@types/winston": "^2.4.4",
    "base64-url": "^2.3.3",
    "blocked-at": "^1.2.0",
    "body-parser": "^1.20.3",
    "csv-parse": "^4.12.0",
    "datauri": "^1.0.5",
    "dotenv": "^5.0.1",
    "exceljs": "^4.4.0",
    "express": "^4.21.1",
    "express-winston": "^4.2.0",
    "google-auth-library": "^7.14.1",
    "googleapis": "^59.0.0",
    "normalize-url": "4.0.0",
    "oboe": "^2.1.5",
    "p-queue": "^6.6.2",
    "raven": "^2.6.4",
    "request": "https://github.com/request/request/archive/392db7d127536ff296fb06492db9430790a32d6c.tar.gz",
    "sanitize-filename": "^1.6.3",
    "semver": "^5.7.1",
    "ts-node": "^10.9.2",
    "tslint-language-service": "^0.9.9",
    "typescript": "^5.7.3",
    "winston": "^2.4.5",
    "xlsx": "^0.18.5",
    "yarn": "^1.22.18"
  },
  "typings": "lib/index",
  "engines": {
    "node": ">=20.16.0",
    "yarn": ">=1.19.1"
  },
  "packageManager": "yarn@1.19.1",
  "resolutions": {
    "**/@types/express": "^4.17.17",
    "**/event-stream": "3.3.4",
    "**/extend": "^3.0.2",
    "**/qs": "^6.9.0",
    "**/just-extend": "^4.0.2",
    "**/jsonwebtoken": "^9.0.0",
    "**/request": "https://github.com/request/request/archive/392db7d127536ff296fb06492db9430790a32d6c.tar.gz",
    "**/lodash": "^4.17.20",
    "**/netmask": "^2.0.1",
